# ─────────────────────────────────────────────────────────────────
#  SparesMaster — Environment Variables
#
#  HOW TO USE:
#    cp .env.example .env
#    Edit .env with your real values
#    Never commit .env to Git!
# ─────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────
# Port the Express server listens on
# Render / Railway will inject their own PORT automatically
PORT=3000

# Node environment: development | production | test
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────────
# Path to the SQLite file (relative to the backend/ folder)
# The folder is created automatically on first run
DB_PATH=./db/inventory.db

# ── CORS ─────────────────────────────────────────────────────────
# Allowed frontend origins (comma-separated)
# Development:  * (allow everything)
# Production:   https://your-app.onrender.com
CORS_ORIGIN=*

# ── Rate Limiting ────────────────────────────────────────────────
# Window in milliseconds (default = 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
# Max requests per IP per window
RATE_LIMIT_MAX=100

# ── Logging ──────────────────────────────────────────────────────
# Log verbosity: error | warn | info | debug
LOG_LEVEL=info
