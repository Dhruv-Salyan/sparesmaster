# ─────────────────────────────────────────────────────────────────
#  SparesMaster — .gitignore
# ─────────────────────────────────────────────────────────────────

# ── Environment & secrets ────────────────────────────────────────
.env
.env.local
.env.production
.env.*.local

# ── Database (never commit the live DB) ─────────────────────────
backend/db/
*.db
*.sqlite
*.sqlite3

# ── Node.js ──────────────────────────────────────────────────────
node_modules/
backend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# ── Logs ─────────────────────────────────────────────────────────
logs/
backend/logs/
*.log

# ── OS & editor junk ─────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Build output (TypeScript compiled JS lives in js/ but is
#    checked in so the app works without a build step) ────────────
dist/
build/
*.tsbuildinfo

# ── Misc ─────────────────────────────────────────────────────────
.cache/
.temp/
coverage/
