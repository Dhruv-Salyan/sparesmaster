# ─────────────────────────────────────────────────
#  Optimum Inventory Control — Environment Config
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# Database  (relative to project root)
DB_PATH=./db/inventory.db

# CORS — comma-separated list of allowed origins
#   development: * (allow all)
#   production:  https://yourdomain.com
CORS_ORIGIN=*

# Rate limiting (requests per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logging level: error | warn | info | debug
LOG_LEVEL=info

# ── Authentication ────────────────────────────────────────────
# REQUIRED: Change this to a long random string in production!
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_use_a_long_random_secret_string

# JWT expiry for normal logins (e.g. 7d, 24h, 1h)
JWT_EXPIRES=7d

# Frontend URL (used to build password-reset links in emails)
FRONTEND_URL=http://localhost:3000
